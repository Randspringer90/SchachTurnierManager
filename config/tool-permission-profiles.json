{
  "schemaVersion": 1,
  "description": "Least-Privilege-Toolprofile je Risikoklasse. Agenten referenzieren ein Profil (permissionProfile in agent-manifest.json).",
  "profiles": {
    "high-risk": {
      "allowed": ["Read", "Grep", "Glob"],
      "forbidden": ["Edit", "Write", "git-push", "git-history-rewrite", "network", "secret-read-during-untrusted", "tag", "release"],
      "humanApprovalForMutations": true
    },
    "medium-risk": {
      "allowed": ["Read", "Grep", "Glob", "Edit", "Write"],
      "forbidden": ["git-push", "git-history-rewrite", "network-during-untrusted", "secret-read-during-untrusted", "tag", "release"],
      "humanApprovalForMutations": false
    },
    "low-risk": {
      "allowed": ["Read", "Grep", "Glob", "Edit", "Write"],
      "forbidden": ["git-push", "git-history-rewrite", "tag", "release"],
      "humanApprovalForMutations": false
    },
    "reviewer": {
      "allowed": ["Read", "Grep", "Glob"],
      "forbidden": ["Edit", "Write", "git-push", "network", "secret-read"],
      "canBlock": true
    }
  },
  "globalForbidden": ["force-push", "reset-hard", "clean-fd", "history-rewrite", "auto-merge-foreign-pr", "commit-secrets-or-pii"]
}
