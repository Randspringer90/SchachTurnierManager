{
  "schemaVersion": 1,
  "description": "Least-Privilege-Toolprofile je Risikoklasse. Effektive Rechte sind die Schnittmenge aus Profil-allowed und der Erlaubte-Tools-Liste des Agenten; jede agenten-, profil- oder globalForbidden-Regel hat Vorrang.",
  "profiles": {
    "high-risk": {
      "allowed": ["Read", "Grep", "Glob", "Edit", "Write", "Bash-tests"],
      "forbidden": ["git-push", "git-history-rewrite", "network", "secret-read-during-untrusted", "tag", "release"],
      "humanApprovalForMutations": true
    },
    "medium-risk": {
      "allowed": ["Read", "Grep", "Glob", "Edit", "Write", "Bash-tests"],
      "forbidden": ["git-push", "git-history-rewrite", "network-during-untrusted", "secret-read-during-untrusted", "tag", "release"],
      "humanApprovalForMutations": false
    },
    "low-risk": {
      "allowed": ["Read", "Grep", "Glob", "Edit", "Write"],
      "forbidden": ["git-push", "git-history-rewrite", "tag", "release"],
      "humanApprovalForMutations": false
    },
    "reviewer": {
      "allowed": ["Read", "Grep", "Glob"],
      "forbidden": ["Edit", "Write", "git-push", "network", "secret-read"],
      "canBlock": true
    },
    "pr-review-static": {
      "allowed": ["Read", "Grep", "Glob", "GitHubMetadataRead", "WriteReviewArtifacts"],
      "forbidden": ["Edit", "Write", "restore", "build", "test", "install", "merge", "git-push", "arbitrary-network", "secret-read"],
      "humanApprovalForMutations": true,
      "canBlock": true
    },
    "pr-integration-controlled": {
      "allowed": ["Read", "Grep", "Glob", "Edit", "Write", "restore", "build", "test"],
      "forbidden": ["execute-foreign-script", "unapproved-install", "network-during-untrusted", "secret-read", "merge-foreign-pr", "git-push", "tag", "release"],
      "humanApprovalForMutations": true,
      "canBlock": true
    }
  },
  "globalForbidden": ["force-push", "reset-hard", "clean-fd", "history-rewrite", "auto-merge-foreign-pr", "commit-secrets-or-pii"]
}
