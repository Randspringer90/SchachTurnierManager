{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://randspringer90.github.io/SchachTurnierManager/schemas/model-routing.schema.json",
  "title": "SchachTurnierManager model routing policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schemaVersion", "description", "policy", "qualityClassRank", "profiles", "selectionRules", "unmatchedRoute", "auditFields"],
  "properties": {
    "$schema": { "const": "./model-routing.schema.json" },
    "schemaVersion": { "const": 2 },
    "description": { "type": "string", "minLength": 20 },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["qualityOverCost", "noSilentModelSwitch", "noAutomaticDowngradeForCriticalWork", "profileAvailabilityMustBeConfirmedByRuntime", "unavailableProfileAction", "criticalTaskCategories"],
      "properties": {
        "qualityOverCost": { "const": true },
        "noSilentModelSwitch": { "const": true },
        "noAutomaticDowngradeForCriticalWork": { "const": true },
        "profileAvailabilityMustBeConfirmedByRuntime": { "const": true },
        "unavailableProfileAction": { "const": "block-and-request-explicit-reroute" },
        "criticalTaskCategories": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "qualityClassRank": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 1 },
      "required": ["local-deterministic", "standard-low-risk", "strongest-implementation", "strongest-planning", "human-required"]
    },
    "profiles": {
      "type": "array",
      "minItems": 6,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "displayName", "purpose", "qualityClass", "allowedRisk", "deterministicOnly"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "displayName": { "type": "string", "minLength": 2 },
          "purpose": { "type": "string", "minLength": 10 },
          "qualityClass": { "enum": ["strongest-planning", "strongest-implementation", "standard-low-risk", "local-deterministic", "human-required"] },
          "allowedRisk": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["low", "medium", "high", "critical"] } },
          "deterministicOnly": { "type": "boolean" }
        }
      }
    },
    "selectionRules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "priority", "profile", "minimumQualityClass", "reason"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "priority": { "type": "integer", "minimum": 1 },
          "taskCategories": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
          "workModes": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["orchestration", "planning", "architecture", "implementation", "review", "final-integration", "bulk"] } },
          "sizes": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["small", "medium", "large"] } },
          "risks": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["low", "medium", "high", "critical"] } },
          "requiresDeterministic": { "type": "boolean" },
          "profile": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "minimumQualityClass": { "enum": ["strongest-planning", "strongest-implementation", "standard-low-risk", "local-deterministic", "human-required"] },
          "reason": { "type": "string", "minLength": 10 }
        }
      }
    },
    "unmatchedRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reason"],
      "properties": {
        "status": { "const": "human-required" },
        "reason": { "type": "string", "minLength": 10 }
      }
    },
    "auditFields": { "type": "array", "minItems": 10, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
  }
}
