{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "task-decomposition-policy.schema.json",
  "title": "STM Task-Decomposition-Policy",
  "type": "object",
  "required": [
    "schemaVersion",
    "orchestratorProfiles",
    "finalIntegratorProfiles",
    "criticalFinalDecisionProfiles",
    "maxDelegationDepth",
    "maxParallelWriters",
    "criticalCategories",
    "delegationGate",
    "qualityEscalation",
    "defaults",
    "requiredTaskFields",
    "statusValues",
    "integrationGate"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "description": { "type": "string" },
    "orchestratorProfiles": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "finalIntegratorProfiles": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "criticalFinalDecisionProfiles": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "maxDelegationDepth": { "type": "integer", "minimum": 1, "maximum": 4 },
    "maxParallelWriters": { "type": "integer", "minimum": 1, "maximum": 1 },
    "readOnlyAnalystsMayRunInParallel": { "type": "boolean" },
    "childrenMayCommit": { "type": "boolean", "const": false },
    "childrenMayPush": { "type": "boolean", "const": false },
    "childOutputTrustZone": { "type": "string", "const": "T3" },
    "criticalCategories": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "delegationGate": {
      "type": "object",
      "required": [
        "requiresBoundedScope",
        "requiresDefinedResultFormat",
        "requiresDeterministicOrTestableResult",
        "requiresKnownFiles",
        "requiresMinimumQuality",
        "requiresStrongerFinalReview"
      ],
      "additionalProperties": { "type": "boolean" }
    },
    "qualityEscalation": {
      "type": "object",
      "required": ["onInsufficientQuality", "escalationOrder"],
      "properties": {
        "onInsufficientQuality": { "type": "array", "items": { "type": "string" } },
        "escalationOrder": {
          "type": "object",
          "additionalProperties": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "defaults": {
      "type": "object",
      "required": ["tokenBudget", "timeoutSeconds", "minimumQuality", "resultFormat"],
      "properties": {
        "tokenBudget": { "type": "integer", "minimum": 100 },
        "timeoutSeconds": { "type": "integer", "minimum": 10 },
        "minimumQuality": { "type": "string" },
        "resultFormat": { "type": "string" }
      }
    },
    "requiredTaskFields": { "type": "array", "items": { "type": "string" }, "minItems": 10 },
    "statusValues": { "type": "array", "items": { "type": "string" }, "minItems": 5 },
    "integrationGate": {
      "type": "object",
      "required": [
        "onlyReviewedResultsMayIntegrate",
        "reviewerMustBeStrongerOrEqualQualityClass",
        "quarantinedOutputNeverIntegrates",
        "childOutputNeverBecomesInstructionSource"
      ],
      "additionalProperties": { "type": "boolean" }
    }
  }
}
