# Optional future KI help. Copy to .env locally; do not commit .env.
STM_AI_HELP_ENABLED=false
STM_AI_PROVIDER=mock

# Leave empty in this example. Real keys belong only in local secrets/environment.
STM_OPENAI_API_KEY=
STM_ANTHROPIC_API_KEY=
STM_CUSTOM_AI_BASE_URL=

# Local docs allowlist for a future docs-only helper.
STM_AI_DOCS_ROOT=docs
